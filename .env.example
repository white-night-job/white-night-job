# 本番サイトURL（OGP・構造化データ用）
NEXT_PUBLIC_SITE_URL=https://www.whitenightjob.jp

NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_SHOP_IMAGE_BUCKET=shop-images

# /admin の簡易ログイン用
ADMIN_PASSWORD=change-this-password
ADMIN_SESSION_SECRET=change-this-long-random-secret

# ブラック店報告の通知メール（Resend 優先）
RESEND_API_KEY=re_xxxxxxxx
REPORT_EMAIL=whitenightjob.info@gmail.com
RESEND_FROM_EMAIL=White Night Job <noreply@your-domain.com>

# Resend 未設定時の Nodemailer フォールバック（任意）
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-smtp-user
# SMTP_PASS=your-smtp-password
# SMTP_FROM=White Night Job <your-smtp-user>

# White Night相談Bot（OpenAI API）
OPENAI_API_KEY=sk-xxxxxxxx

# 求職者向けLINEログイン / 通知
LINE_LOGIN_CHANNEL_ID=2000000000
LINE_LOGIN_CHANNEL_SECRET=your-line-login-channel-secret
# 本番: https://www.whitenightjob.jp/api/auth/line/callback
# ローカル: http://localhost:3000/api/auth/line/callback
# ※末尾に改行を入れないこと（Vercel環境変数で %0A が付くとLINE認証が失敗します）
LINE_LOGIN_REDIRECT_URI=http://localhost:3000/api/auth/line/callback
LINE_MESSAGING_CHANNEL_ACCESS_TOKEN=your-line-messaging-channel-access-token
LINE_MESSAGING_CHANNEL_SECRET=your-line-messaging-channel-secret
USER_SESSION_SECRET=change-this-user-session-secret
# www/apex 両方でCookie共有が必要な場合のみ設定（例: .whitenightjob.jp）
# COOKIE_DOMAIN=.whitenightjob.jp
